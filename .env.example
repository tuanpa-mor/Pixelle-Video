# Pixelle-Video root environment overrides.
#
# Copy to `.env` (or `docker-compose` env) to override the defaults in
# config.yaml / config.example.yaml. Anything not listed here falls
# back to the value declared in `config.yaml`.

# ============================================================================
# Auth (Phase 1 backend)
# ============================================================================
# JWT signing key. MUST be overridden in production. A long random
# string is recommended; a 32-byte base64 secret is more than enough.
JWT_SECRET=change-me-in-production-use-a-long-random-string

# Path to the SQLite database that stores users + refresh tokens.
# Inside the api container this should resolve to a path that's
# persisted via a volume (the default `./data/auth.db` works because
# docker-compose mounts `./data` into the api container at `/app/data`).
AUTH_DB_PATH=data/auth.db

# Optional: Google OAuth (id_token verification). Leave disabled unless
# you have configured a Google Identity Services client.
GOOGLE_CLIENT_ID=
GOOGLE_ENABLED=false

# ============================================================================
# Next.js web client (web-next/)
# ============================================================================
# Absolute URL the browser uses to reach the FastAPI backend. Leave
# empty in dev so the Next.js rewrite proxy (see next.config.mjs) is
# used; set this in production if /api/* isn't reverse-proxied.
#
# For local dev without Docker, copy this value to `web-next/.env` so
# Next.js can read it at build/dev time.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8001

# Where Next.js proxies /api/* during `next dev`. In Docker the
# api service is reachable at http://api:8001; on the host it's
# http://localhost:8001.
API_PROXY_TARGET=http://127.0.0.1:8001
