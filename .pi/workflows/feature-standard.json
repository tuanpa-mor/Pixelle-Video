{
  "id": "feature-standard",
  "name": "Feature Standard",
  "description": "Workflow đầy đủ cho feature mới, gồm spec, plan, review, enrich, readiness và execute trong Pi.",
  "steps": [
    {
      "id": "create-spec",
      "title": "Create spec",
      "type": "command",
      "value": "/create-spec",
      "hint": "Gõ /create-spec \"mô tả feature\""
    },
    {
      "id": "review-spec",
      "title": "Review spec",
      "type": "sub-agent",
      "value": "/review-spec",
      "hint": "Gõ /review-spec @docs/ai/specs/<file>.md"
    },
    {
      "id": "create-plan",
      "title": "Create plan",
      "type": "command",
      "value": "/create-plan",
      "hint": "Gõ /create-plan @docs/ai/specs/<file>.md"
    },
    {
      "id": "review-plan",
      "title": "Review plan",
      "type": "sub-agent",
      "value": "/review-plan",
      "hint": "Gõ /review-plan @docs/ai/plans/<file>.md"
    },
    {
      "id": "enrich-plan",
      "title": "Enrich plan",
      "type": "sub-agent",
      "value": "/enrich-plan-pi --review-plan",
      "hint": "Gõ /enrich-plan-pi docs/ai/plans/<file>.md --review-plan"
    },
    {
      "id": "review-readiness",
      "title": "Review readiness",
      "type": "sub-agent",
      "value": "/review-readiness --brief",
      "hint": "Gõ /review-readiness @spec.md @plan.md @detail-1.md [@detail-2.md ...] --brief"
    },
    {
      "id": "execute-plan",
      "title": "Execute plan",
      "type": "command",
      "value": "/execute-plan",
      "hint": "Gõ /execute-plan docs/ai/plans/<file>.md"
    },
    {
      "id": "verify-feature",
      "title": "Verify feature",
      "type": "skill",
      "value": "verify-feature",
      "hint": "Yêu cầu agent verify feature theo spec sau khi implement xong"
    }
  ]
}
